{
  "info": {
    "name": "FlowPay Attendance API",
    "description": "Import this collection for a flat folder layout (Tickets + Dashboard).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "ticketId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Problemas com cartão\"\n}"
            },
            "url": "{{baseUrl}}/api/tickets"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('ticketId', body.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Complete ticket",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/tickets/{{ticketId}}/complete"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/summary"
          }
        }
      ]
    }
  ]
}
