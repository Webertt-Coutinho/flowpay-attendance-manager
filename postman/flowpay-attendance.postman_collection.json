{
  "info": {
    "name": "FlowPay Attendance API",
    "description": "Collection para testar a API FlowPay Attendance.\n\nFluxo sugerido:\n1. Create ticket (qualquer equipe)\n2. Get summary\n3. Complete ticket\n\nA variável ticketId é preenchida automaticamente após criar um ticket.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "ticketId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create ticket — CARTOES",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Problemas com cartão\"\n}"
            },
            "url": "{{baseUrl}}/api/tickets",
            "description": "Roteia para a equipe CARTOES."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('ticketId', body.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create ticket — EMPRESTIMOS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Contratação de empréstimo\"\n}"
            },
            "url": "{{baseUrl}}/api/tickets",
            "description": "Roteia para a equipe EMPRESTIMOS."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('ticketId', body.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create ticket — OUTROS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Dúvida geral\"\n}"
            },
            "url": "{{baseUrl}}/api/tickets",
            "description": "Qualquer assunto não mapeado roteia para OUTROS."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('ticketId', body.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Complete ticket",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/tickets/{{ticketId}}/complete",
            "description": "Conclui o ticket cujo id está em {{ticketId}}. Execute um Create ticket antes."
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/summary",
            "description": "Retorna totalQueued, totalActive, totalCompleted e queuesByTeam."
          }
        }
      ]
    }
  ]
}